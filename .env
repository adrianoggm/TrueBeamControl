# Configuracion de grafi. Descomenta y edita lo que necesites.
# Se carga automaticamente al ejecutar programa_graficar.py.

# Carpeta con los CSV
GRAFI_DATA_DIR=data

# Formato de fecha en el eje X (dia/mes/ano hora)
GRAFI_DATE_FORMAT=%d/%m/%Y %H:%M

# Columna de fechas
GRAFI_DATE_COL=Date

# Columna numerica a graficar
GRAFI_VALUE_COL=BeamGroup/BeamOutputChange [%]

# Grafica a generar (ver PLOTTERS)
GRAFI_PLOT=tolerancia

# Energias del selector
GRAFI_ENERGIAS=6x,6xFFF,10xFFF,15x

# Energia fija sin preguntar (opcional)
# GRAFI_ENERGIA=6x

# CSV concreto; salta el selector de energia (opcional)
# GRAFI_FILE=data/Measdata 2026-07-03 12'31'42.csv
